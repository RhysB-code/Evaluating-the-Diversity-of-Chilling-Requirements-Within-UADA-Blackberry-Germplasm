# ── Potted (Long-Cane) ────────────────────────────────────────────────────────
p_days <- seq(7, 70, 7)
p_treat_levels <- c("0", "1", "2", "3", "4", "5")
p_treat_labels <- c("0", "168", "336", "504", "672", "840")

potted_raw <- read.csv(
    paste0(
        "C:/Users/RhysB/OneDrive/Desktop/CH1 Complement vs Potted/",
        "Potted_Data(2024-2025)/Analysis_Spreadsheet__Potted_Final__ForR.csv"
    ),
    check.names = TRUE
)
names(potted_raw) <- make.names(trimws(names(potted_raw)), unique = TRUE)
names(potted_raw)[1] <- "Genotype"
if ("Rep" %in% names(potted_raw)) {
    names(potted_raw)[names(potted_raw) == "Rep"] <- "Replicate"
}

potted <- potted_raw %>%
    dplyr::filter(
        !is.na(Genotype), Genotype != "",
        !is.na(Treatment), Treatment != ""
    ) %>%
    dplyr::mutate(
        Genotype = factor(Genotype, levels = GENO_LEVELS),
        Treatment = factor(Treatment,
            levels = p_treat_levels, labels = p_treat_labels
        )
    )

reshape_potted <- function(df, suffix, trait) {
    id <- intersect(c("Genotype", "Treatment", "Replicate", "Rep"), names(df))
    keep <- intersect(c(
        paste0("X", p_days, "Day_Potted_", suffix),
        paste0(p_days, "Day_Potted_", suffix)
    ), names(df))
    if (!length(keep)) {
        return(tibble::tibble())
    }
    df %>%
        dplyr::select(dplyr::any_of(id), dplyr::any_of(keep)) %>%
        tidyr::pivot_longer(dplyr::any_of(keep),
            names_to = "DC", values_to = "Value"
        ) %>%
        dplyr::mutate(
            Day   = as.numeric(stringr::str_match(DC, "X?(\\d+)Day_")[, 2]),
            Trait = trait
        ) %>%
        dplyr::filter(!is.na(Value))
}

p_long <- purrr::map2_dfr(
    traits, suffixes,
    ~ reshape_potted(potted, .y, .x)
) %>%
    dplyr::group_by(Trait) %>%
    dplyr::mutate(Value_disp = dplyr::if_else(
        Trait %in% PERCENT_TRAITS & max(Value, na.rm = TRUE) <= 1,
        Value * 100, Value
    )) %>%
    dplyr::ungroup() %>%
    dplyr::mutate(Value_t = mapply(apply_transform_obs, Value_disp, Trait))

id_col_p <- intersect(c("Replicate", "Rep"), names(p_long))
p_long$.rep <- if (length(id_col_p)) {
    p_long[[id_col_p[1]]]
} else {
    seq_len(nrow(p_long))
}

p_aupc_reps <- p_long %>%
    dplyr::arrange(Genotype, Treatment, Trait, .rep, Day) %>%
    dplyr::group_by(Genotype, Treatment, Trait, .rep) %>%
    dplyr::summarise(
        AUPC = compute_auc(Day, Value_disp),
        AUPC_t = compute_auc(Day, Value_t), .groups = "drop"
    )
