# ── Helpers ───────────────────────────────────────────────────────────────────

# Write CSV with BOM so Excel on Windows reads the file as UTF-8.
# "UTF-8-BOM" is not recognised by all R builds, so we prepend the BOM
# code-point (\ufeff) directly to the first line instead.
write_utf8 <- function(lines, filepath) {
    lines[1] <- paste0("\ufeff", lines[1])
    con <- file(filepath, open = "w", encoding = "UTF-8")
    writeLines(lines, con = con)
    close(con)
    message("Saved: ", basename(filepath))
}

q <- function(x) paste0('"', gsub('"', '""', as.character(x)), '"')

save_fig <- function(p, fname, w, h, dpi = 400) {
    ggsave(file.path(OUT, fname),
        plot = p,
        width = w, height = h, dpi = dpi, bg = "white"
    )
    message("Saved: ", fname)
}

apply_transform_obs <- function(x, trait) {
    if (trait %in% PERCENT_TRAITS) {
        asin(sqrt(pmin(pmax(x / 100, 0), 1)))
    } else {
        log1p(x)
    }
}

compute_auc <- function(x, y) {
    if (length(x) < 2) {
        return(0)
    }
    sum((head(y, -1) + tail(y, -1)) / 2 * diff(x))
}

fmt_p <- function(p) {
    if (is.na(p) || !is.finite(p)) {
        return("NA")
    }
    if (p < 0.0001) {
        return("< 0.0001")
    }
    formatC(p, digits = 4, format = "f")
}

compress_letters <- function(x) {
    x <- stringr::str_trim(x)
    ch <- strsplit(x, "")[[1]]
    if (length(ch) <= 2) {
        return(x)
    }
    pos <- match(ch, base::letters)
    if (!anyNA(pos) && all(diff(pos) == 1L)) {
        paste0(ch[1], "-", ch[length(ch)])
    } else {
        x
    }
}
