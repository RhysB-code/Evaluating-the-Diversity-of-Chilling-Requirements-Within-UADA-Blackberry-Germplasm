# ── Constants ─────────────────────────────────────────────────────────────────
ALPHA <- 0.05
PERCENT_TRAITS <- c("Budbreak", "Floral Laterals")
traits <- c("Budbreak", "Floral Laterals", "Open Flowers")
suffixes <- c("Budbreak", "FloralLaterals", "OpenFlowers")
GENO_LEVELS <- c("A-2491T", "Natchez", "Navaho", "Ouachita", "Ponca", "Von")
