```{r table1}
# ── Table 1: Assumption Tests ─────────────────────────────────────────────────
run_assumptions <- function(aupc_df, study_label) {
    purrr::map_dfr(traits, function(tr) {
        d <- dplyr::filter(aupc_df, Trait == tr)
        if (nrow(d) < 6) {
            return(NULL)
        }
        run_one <- function(col, scale_lbl) {
            mod <- suppressWarnings(
                aov(as.formula(paste(col, "~ Genotype * Treatment")), data = d)
            )
            shap <- shapiro.test(residuals(mod))
            lev <- suppressWarnings(
                car::leveneTest(
                    as.formula(paste(col, "~ Genotype * Treatment")),
                    data = d, center = median
                )
            )
            data.frame(
                Trait = tr, Scale = scale_lbl, Study = study_label,
                Levene_p = round(lev[1, "Pr(>F)"], 6),
                SW_p = round(shap$p.value, 6)
            )
        }
        scale_trans <- dplyr::case_when(
            tr == "Budbreak" ~ "Budbreak (arcsine sqrt-p)",
            tr == "Floral Laterals" ~ "Floral Laterals (arcsine sqrt-p)",
            TRUE ~ "Open Flowers [log(x + 1)]"
        )
        dplyr::bind_rows(run_one("AUPC", tr), run_one("AUPC_t", scale_trans))
    })
}

assump_all <- dplyr::bind_rows(
    run_assumptions(p_aupc_reps, "Long-Cane"),
    run_assumptions(c_aupc_reps, "Field Cutting Y1"),
    run_assumptions(c2_aupc_reps, "Field Cutting Y2")
) %>%
    dplyr::mutate(
        Levene_fmt = sapply(Levene_p, fmt_p),
        SW_fmt = sapply(SW_p, fmt_p)
    )

write_table1_csv <- function(df, filepath) {
    row_order <- c(
        "Budbreak", "Budbreak (arcsine sqrt-p)",
        "Floral Laterals", "Floral Laterals (arcsine sqrt-p)",
        "Open Flowers", "Open Flowers [log(x + 1)]"
    )
    studies <- c("Long-Cane", "Field Cutting Y1", "Field Cutting Y2")
    lines <- c(
        paste(q("Table 1: Assumption Tests"), q("Levene"), q(""), q(""),
            q("Shapiro-Wilk"), q(""), q(""),
            sep = ","
        ),
        paste(q(""), q("Long-Cane"), q("Field Cutting Y1"),
            q("Field Cutting Y2"), q("Long-Cane"),
            q("Field Cutting Y1"), q("Field Cutting Y2"),
            sep = ","
        )
    )
    for (sc in row_order) {
        sub <- dplyr::filter(df, Scale == sc)
        lv <- sapply(studies, function(s) {
            v <- sub$Levene_fmt[sub$Study == s]
            if (!length(v)) "NA" else v
        })
        sw <- sapply(studies, function(s) {
            v <- sub$SW_fmt[sub$Study == s]
            if (!length(v)) "NA" else v
        })
        lines <- c(
            lines,
            paste(q(sc), q(lv[1]), q(lv[2]), q(lv[3]),
                q(sw[1]), q(sw[2]), q(sw[3]),
                sep = ","
            )
        )
    }
    write_utf8(lines, filepath)
}

