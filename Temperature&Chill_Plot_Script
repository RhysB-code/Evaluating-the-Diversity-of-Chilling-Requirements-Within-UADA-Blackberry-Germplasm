```{r build-diag}
# ── Build z-scored diagnostic data for all 9 Study x Trait panels ─────────────
study_list <- list(
    "Long-Cane"        = p_aupc_reps,
    "Field Cutting Y1" = c_aupc_reps,
    "Field Cutting Y2" = c2_aupc_reps
)

all_diag <- purrr::map_dfr(names(study_list), function(sname) {
    adf <- study_list[[sname]]
    purrr::map_dfr(traits, function(tr) {
        d <- dplyr::filter(adf, Trait == tr)
        if (nrow(d) < 6) {
            return(NULL)
        }
        rm <- suppressWarnings(aov(AUPC ~ Genotype * Treatment, data = d))
        tm <- suppressWarnings(aov(AUPC_t ~ Genotype * Treatment, data = d))
        dplyr::bind_rows(
            data.frame(
                Study = sname, Trait = tr, Scale = "Raw",
                Resid = residuals(rm), Fitted = fitted(rm)
            ),
            data.frame(
                Study = sname, Trait = tr, Scale = "Transformed",
                Resid = residuals(tm), Fitted = fitted(tm)
            )
        )
    })
}) %>%
    dplyr::group_by(Study, Trait, Scale) %>%
    dplyr::mutate(
        Resid_z = as.vector(scale(Resid)),
        Fitted_z = as.vector(scale(Fitted))
    ) %>%
    dplyr::ungroup() %>%
    dplyr::mutate(
        Trait = factor(Trait, levels = traits),
        Study = factor(Study,
            levels = c("Long-Cane", "Field Cutting Y1", "Field Cutting Y2")
        ),
        Scale = factor(Scale,
            levels = c("Raw", "Transformed"),
            labels = c("Raw AUPC", "Transformed AUPC")
        )
    )

qq_data <- all_diag %>%
    dplyr::group_by(Study, Trait, Scale) %>%
    dplyr::arrange(Resid_z, .by_group = TRUE) %>%
    dplyr::mutate(theoretical = qnorm(ppoints(dplyr::n()))) %>%
    dplyr::ungroup()

ref_grid <- dplyr::distinct(all_diag, Study, Trait) %>%
    dplyr::mutate(x_seq = list(seq(-4.5, 4.5, length.out = 300))) %>%
    tidyr::unnest(x_seq) %>%
    dplyr::mutate(density = dnorm(x_seq))
