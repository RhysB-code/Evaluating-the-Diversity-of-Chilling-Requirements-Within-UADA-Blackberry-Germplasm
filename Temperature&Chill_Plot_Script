    theme_bw(base_size = base) +
        theme(
            strip.background = element_rect(fill = "#dce3ea", color = "#7f8c8d"),
            strip.text = element_text(
                face = "bold", size = base - 1,
                color = "#1a3a4a"
            ),
            strip.text.y = element_text(angle = 0, hjust = 0),
            panel.grid.minor = element_blank(),
            panel.grid.major = element_line(color = "#ecf0f1", linewidth = 0.35),
            axis.title = element_text(face = "bold", size = base - 1),
            axis.text = element_text(size = base - 2, color = "#2c3e50"),
            legend.position = "bottom",
            legend.title = element_blank(),
            legend.text = element_text(size = base),
            legend.key.width = unit(2.0, "cm"),
