# ── Table 2: Factorial Results ────────────────────────────────────────────────
# Per chilling treatment, all three studies combined.
# Mean +/- SE: G x T cell emmeans (least-squares means +/- SE from two-way model).
# Letters: Tukey HSD and Scott-Knott across ALL G x T cells simultaneously.
# Budbreak and Floral Laterals only; Open Flowers excluded from inference.

get_gxt_emmeans <- function(df, col) {
    mod <- suppressWarnings(
        aov(as.formula(paste(col, "~ Genotype * Treatment")), data = df)
    )
    emm <- suppressMessages(
        as.data.frame(
            summary(emmeans::emmeans(mod, ~ Genotype * Treatment))
        )
    )
    emm %>%
        dplyr::transmute(
            Genotype  = as.character(Genotype),
            Treatment = as.character(Treatment),
            Mean_SE   = paste0(round(emmean, 2), " \u00b1 ", round(SE, 3))
        )
}

get_tukey_gxt <- function(df, col) {
    mod <- suppressWarnings(
        aov(as.formula(paste(col, "~ Genotype * Treatment")), data = df)
    )
    emm <- suppressMessages(emmeans::emmeans(mod, ~ Genotype * Treatment))
    cld <- suppressMessages(
        multcomp::cld(emm,
            Letters = letters, adjust = "tukey",
            alpha = ALPHA, reversed = TRUE
        )
    )
    as.data.frame(cld) %>%
        dplyr::transmute(
            Genotype  = as.character(Genotype),
            Treatment = as.character(Treatment),
            Letters   = sapply(stringr::str_trim(.group), compress_letters)
        )
}

get_sk_gxt <- function(df, col) {
    mod <- suppressWarnings(
        aov(as.formula(paste(col, "~ Genotype * Treatment")), data = df)
    )
    MSe <- sigma(mod)^2
    chi2_c <- qchisq(1 - ALPHA, df = 1)
    mu_mat <- tapply(df[[col]],
        list(
            as.character(df$Genotype),
            as.character(df$Treatment)
        ),
        mean,
        na.rm = TRUE
    )
    n_mat <- tapply(
        df[[col]],
        list(
            as.character(df$Genotype),
            as.character(df$Treatment)
        ),
        length
    )
    cells <- data.frame(
        Genotype = rep(rownames(mu_mat), times = ncol(mu_mat)),
        Treatment = rep(colnames(mu_mat), each = nrow(mu_mat)),
        mu = as.vector(mu_mat),
        n = as.vector(n_mat),
        stringsAsFactors = FALSE
    )
    cells <- cells[!is.na(cells$mu), ]
    cells <- cells[order(-cells$mu), ]
    rownames(cells) <- seq_len(nrow(cells))

    sk_part <- function(idx) {
        K <- length(idx)
        if (K <= 1L) {
            return(list(idx))
        }
        m <- cells$mu[idx]
        n <- cells$n[idx]
        N <- sum(n)
        S <- sum(n * m)
        best_SS <- -Inf
        best_k <- 1L
        cn <- 0
        cs <- 0
        for (k in seq_len(K - 1L)) {
            cn <- cn + n[k]
            cs <- cs + n[k] * m[k]
            SS_k <- cs^2 / cn + (S - cs)^2 / (N - cn) - S^2 / N
            if (SS_k > best_SS) {
                best_SS <- SS_k
                best_k <- k
            }
        }
        if (best_SS / MSe <= chi2_c) {
            return(list(idx))
        }
        c(sk_part(idx[seq_len(best_k)]), sk_part(idx[(best_k + 1L):K]))
    }

    groups <- sk_part(seq_len(nrow(cells)))
    cells$Letters <- ""
    for (gi in seq_along(groups)) {
        lbl <- if (gi <= 26L) letters[gi] else paste0("z", gi - 26L)
        cells$Letters[groups[[gi]]] <- lbl
    }
    cells[, c("Genotype", "Treatment", "Letters")]
}

get_anova_p <- function(df, col) {
    mod <- suppressWarnings(
        aov(as.formula(paste(col, "~ Genotype * Treatment")), data = df)
    )
    s <- broom::tidy(mod)
    list(
        G = fmt_p(s$p.value[s$term == "Genotype"]),
        T = fmt_p(s$p.value[s$term == "Treatment"]),
        GxT = fmt_p(s$p.value[s$term == "Genotype:Treatment"])
    )
}

build_study_gxt <- function(aupc_df, study_label) {
    message("Building table: ", study_label)
    analysis_traits <- c("Budbreak", "Floral Laterals")

    all_data <- setNames(
        lapply(analysis_traits, function(tr) {
            d <- dplyr::filter(aupc_df, Trait == tr) %>%
                dplyr::mutate(
                    Genotype = as.character(Genotype),
                    Treatment = as.character(Treatment)
                )
            emm_raw <- get_gxt_emmeans(d, "AUPC")
            emm_t <- get_gxt_emmeans(d, "AUPC_t")
            tuk_raw <- get_tukey_gxt(d, "AUPC")
            tuk_t <- get_tukey_gxt(d, "AUPC_t")
            sk_t <- get_sk_gxt(d, "AUPC_t")
            anova_pv <- get_anova_p(d, "AUPC")
            merged <- emm_raw %>%
                dplyr::rename(MeanSE_Raw = Mean_SE) %>%
                dplyr::left_join(dplyr::rename(tuk_raw, Tukey_Raw = Letters),
                    by = c("Genotype", "Treatment")
                ) %>%
                dplyr::left_join(dplyr::rename(emm_t, MeanSE_T = Mean_SE),
                    by = c("Genotype", "Treatment")
                ) %>%
                dplyr::left_join(dplyr::rename(tuk_t, Tukey_T = Letters),
                    by = c("Genotype", "Treatment")
                ) %>%
                dplyr::left_join(dplyr::rename(sk_t, SK = Letters),
                    by = c("Genotype", "Treatment")
                )
            list(data = merged, anova = anova_pv)
        }),
        analysis_traits
    )

    treats <- levels(aupc_df$Treatment)
    bb_data <- all_data[["Budbreak"]]$data
    fl_data <- all_data[["Floral Laterals"]]$data
    bb_pv <- all_data[["Budbreak"]]$anova
    fl_pv <- all_data[["Floral Laterals"]]$anova
    rows <- list()

    rows[[1]] <- paste(
        q(paste0(study_label, " \u2014 Factorial Results")),
        q(""), q(""), q(""), q(""), q(""),
        q(""), q(""), q(""), q(""), q(""), q(""),
        sep = ","
    )
    rows[[2]] <- paste(
        q(""),
        q("Budbreak"), q(""), q(""), q(""), q(""),
        q("Floral Laterals"), q(""), q(""), q(""), q(""),
        sep = ","
    )
    rows[[3]] <- paste(
        q(""),
        q("Untransformed"), q(""),
        q("Transformed"), q(""),
        q("Scott-Knott"),
        q("Untransformed"), q(""),
        q("Transformed"), q(""),
        q("Scott-Knott"),
        sep = ","
    )
    rows[[4]] <- paste(
        q("Chill Hours"),
        q("Mean \u00b1 SE (Raw)"), q("Mean Sep. (Raw)"),
        q("Mean \u00b1 SE (Trans.)"), q("Mean Sep. (Trans.)"),
        q("SK (Trans.)"),
        q("Mean \u00b1 SE (Raw)"), q("Mean Sep. (Raw)"),
        q("Mean \u00b1 SE (Trans.)"), q("Mean Sep. (Trans.)"),
        q("SK (Trans.)"),
        sep = ","
    )

    for (g in GENO_LEVELS) {
        rows[[length(rows) + 1]] <- paste(
            q(paste0("--- ", g, " ---")),
            q(""), q(""), q(""), q(""), q(""),
            q(""), q(""), q(""), q(""), q(""),
            sep = ","
        )
        for (trt in treats) {
            gv <- function(df, col) {
                v <- df[[col]][df$Genotype == g & df$Treatment == trt]
                if (length(v) == 0 || is.na(v[1])) "" else as.character(v[1])
            }
            rows[[length(rows) + 1]] <- paste(
                q(trt),
                q(gv(bb_data, "MeanSE_Raw")), q(gv(bb_data, "Tukey_Raw")),
                q(gv(bb_data, "MeanSE_T")),   q(gv(bb_data, "Tukey_T")),
                q(gv(bb_data, "SK")),
                q(gv(fl_data, "MeanSE_Raw")), q(gv(fl_data, "Tukey_Raw")),
                q(gv(fl_data, "MeanSE_T")),   q(gv(fl_data, "Tukey_T")),
                q(gv(fl_data, "SK")),
                sep = ","
            )
        }
    }

    bb_str <- paste0("G: ", bb_pv$G, " | T: ", bb_pv$T, " | G\u00d7T: ", bb_pv$GxT)
    fl_str <- paste0("G: ", fl_pv$G, " | T: ", fl_pv$T, " | G\u00d7T: ", fl_pv$GxT)
    rows[[length(rows) + 1]] <- paste(
        q("ANOVA p-values"),
        q(bb_str), q(""), q(""), q(""), q(""),
        q(fl_str), q(""), q(""), q(""), q(""),
        sep = ","
    )
    rows[[length(rows) + 1]] <- ""

    unlist(rows)
}

